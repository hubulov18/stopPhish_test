{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "seed": "ts-node src/scripts/seed.ts",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "vitest run src/tests/unit/auth.utils.unit.test.ts src/tests/unit/api.authorize.unit.test.ts",
    "test:integration": "vitest run src/tests/integration/api.integration.test.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "jsonwebtoken": "^9.0.2",
    "moleculer": "^0.14.35",
    "moleculer-web": "^0.10.8",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.27"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.16.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.8.3",
    "vitest": "^2.1.8"
  }
}
